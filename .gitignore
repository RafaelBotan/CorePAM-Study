# Data lake — downloaded/generated by scripts, never versioned
01_Base_Pura_CorePAM/
data/raw/
data/processed/

# Heavy binary files
**/*.parquet
**/*.rds
**/*.zip
**/*.tar
**/*.tar.gz
**/*.gz

# Registry (generated during run)
registry/study_registry.csv

# R temporary
.Rhistory
.RData
.Rproj.user/
*.Rproj

# System
.DS_Store
Thumbs.db

# Claude internal state
.claude/

# Technical validation workspace (local only)
tech_validation/

# Execution logs
logs/

# Local-only working files
SESSION_NOTES.md
METHODS_DRAFT.md
RESULTS_SUMMARY.md
ERRORS_LOG.md
PLAN_SYNC.md

# Internal planning documents (not relevant for repo)
CHECKLIST_MASTER_*.md
FIGURES_TABLES_PLAN_*.md
SCRIPTS_PLAN_*.md
01_docs/REVIEWER_RESPONSE_LETTER.md

# Rendered template files (local only)
01_rastreabilidade_metodologica_corepam_template.html
01_rastreabilidade_metodologica_corepam_template_files/

# Manuscript build artifacts (regenerable)
manuscript/references.bib
manuscript/*.pdf
manuscript/*.html

# Submission bundle (regenerable)
submission_bundle/

# Binary spreadsheets (CSV is the canonical format)
**/*.xlsx

# Word documents (local-only by default)
**/*.docx
# Exceptions: submission ground truth + thesis template
!submission/**/*.docx
!tese/reference_abnt_v2.docx

# Submission PDF (ground truth — tracked)
!submission/**/*.pdf

# Thesis build artifacts
tese/*.html

# Qualificacao (local-only, large binary files)
Qualificacao doutorado/

# Stray files
*.tmp
~$*

# Confidential documents
Artigo antigo enviado a springer/
Perguntas dos revisoes.docx
